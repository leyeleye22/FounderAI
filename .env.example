FOUNDER_AI_ENV=development
FOUNDER_AI_HOST=0.0.0.0
FOUNDER_AI_PORT=8010
FOUNDER_AI_MODEL_DIR=/app
FOUNDER_AI_DEFAULT_LOCALE=fr
FOUNDERPATH_API_BASE_URL=https://your-laravel-api.example.com/api
FOUNDERPATH_API_TOKEN=
FOUNDER_AI_USE_LOCAL_HEURISTICS=true
FOUNDER_AI_RAG_DIR=/app/.rag
FOUNDER_AI_RAG_COLLECTION=founderai_knowledge
FOUNDER_AI_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
FOUNDER_AI_FORCE_IN_MEMORY_RETRIEVAL=false

# LLM API settings (recommended for deployment: point to an OpenAI-compatible endpoint)
LLM_API_BASE_URL=
LLM_MODEL_NAME=qwen3-4b-fp8
LLM_REQUEST_TIMEOUT=60
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7
LLM_PRESENCE_PENALTY=0.2
LLM_CHAT_TEMPERATURE=0.7
LLM_CHAT_TOP_P=0.8
LLM_CHAT_MAX_TOKENS=700
LLM_REASONING_TEMPERATURE=0.6
LLM_REASONING_TOP_P=0.95
LLM_REASONING_MAX_TOKENS=1400

# Fine-tuned model settings (optional - local folder or Hugging Face model id)
USE_FINETUNED_MODEL=false
FINETUNED_MODEL_PATH=Qwen/Qwen3-4B
LORA_ADAPTER_PATH=/models/founderai/current/lora_adapter
HF_TOKEN=
